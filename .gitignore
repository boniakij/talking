# Root .gitignore for BaniTalk Project

# OS
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
.project
.settings/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
*.tmp
*.temp
*.cache

# Environment files (except examples)
.env
.env.local
.env.*.local
!.env.example

# Build directories
dist/
build/
out/

# Dependencies (handled in subdirectories)
node_modules/

# Coverage reports
coverage/
*.lcov

# Documentation build
*.html.pdf

# Large files
*.zip
*.tar.gz
*.rar
*.7z

# Database dumps
*.sql
*.dump

# Backup files
*.bak
*.backup
